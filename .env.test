# Placeholder values used by vitest (vite loads .env.test automatically in test mode).
# These satisfy firebase.ts env-var validation; Firebase SDK itself is mocked in test/setup.ts.
# Safe to commit — not real credentials.
VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=test-project
VITE_FIREBASE_STORAGE_BUCKET=test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:test
